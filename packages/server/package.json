{
  "name": "maige-3d-mcp",
  "version": "0.1.0",
  "description": "Multi-framework 3D MCP server for controlling Three.js, A-Frame, Babylon.js, and React Three Fiber scenes with AI. Features in-world chat, 9 AI providers, 33 MCP tools, and WebXR VR support.",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "threejs",
    "aframe",
    "babylonjs",
    "react-three-fiber",
    "3d",
    "webgl",
    "webxr",
    "vr",
    "ai",
    "openai",
    "anthropic",
    "claude",
    "copilot",
    "cursor"
  ],
  "author": "Brendon Smith",
  "license": "MIT",
  "homepage": "https://github.com/m-ai-geXR/maigeXR#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/m-ai-geXR/maigeXR.git",
    "directory": "mcp-webgpu/packages/server"
  },
  "bugs": {
    "url": "https://github.com/m-ai-geXR/maigeXR/issues"
  },
  "type": "module",
  "bin": {
    "maige-3d-mcp": "build/main.js"
  },
  "files": [
    "build/",
    "README.md"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "dev": "tsc && node build/main.js",
    "build": "tsc",
    "start": "node build/main.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.7.0",
    "dotenv": "^16.4.5",
    "open": "^10.1.0",
    "uuid": "^9.0.0",
    "ws": "^8.18.1"
  },
  "optionalDependencies": {
    "@anthropic-ai/sdk": "^0.27.0",
    "openai": "^4.52.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.10",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
