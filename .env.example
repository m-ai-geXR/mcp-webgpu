# ─── Server ────────────────────────────────────────────────────────────────────
# Port the WebSocket bridge listens on (browser clients connect here)
WS_PORT=8083

# Name shown in MCP client tool lists
MCP_SERVER_NAME=maige-3d-mcp


# ─── In-World Chat — Direct AI Mode (optional) ────────────────────────────────
# When set, the MCP server will answer in-world chat messages directly.
# Leave blank to use RELAY mode (an external MCP-capable AI client handles chat).
#
# Set CHAT_PROVIDER to one of:
#   openai | anthropic | google | mistral | groq | xai | cohere | together | ollama
CHAT_PROVIDER=openai


# ─── OpenAI ─────────────────────────────────────────────────────────────────────
# https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Available models:
#   gpt-4.1             — latest flagship (April 2025), 1M context
#   gpt-4.1-mini        — fast & cheap, 1M context
#   gpt-4.1-nano        — ultra-fast, lowest cost
#   gpt-4o              — multimodal flagship (2024)
#   gpt-4o-mini         — fast & cheap
#   o3                  — strongest reasoning
#   o3-mini             — fast reasoning
#   o4-mini             — latest reasoning, efficient
#   gpt-4-turbo         — 128k context, vision
OPENAI_MODEL=gpt-4.1


# ─── Anthropic ──────────────────────────────────────────────────────────────────
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Available models:
#   claude-opus-4-6             — most intelligent, agents + coding (1M ctx)
#   claude-sonnet-4-6           — best speed / intelligence balance (1M ctx)
#   claude-haiku-4-5            — fastest, near-frontier (200k ctx)
#   claude-sonnet-4-20250514    — Claude Sonnet 4.0
#   claude-3-5-sonnet-20241022  — Claude 3.5 Sonnet (legacy)
ANTHROPIC_MODEL=claude-sonnet-4-6


# ─── Google Gemini ──────────────────────────────────────────────────────────────
# https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=

# Available models:
#   gemini-3.1-pro-preview      — latest flagship, advanced reasoning
#   gemini-3-flash-preview      — frontier-class, fast & cheap
#   gemini-3.1-flash-lite-preview — lightest Gemini 3
#   gemini-2.5-pro              — most advanced stable, 1M context
#   gemini-2.5-flash            — fast stable + thinking
#   gemini-2.5-flash-lite       — fastest & cheapest stable
GOOGLE_MODEL=gemini-2.5-flash


# ─── Mistral ────────────────────────────────────────────────────────────────────
# https://console.mistral.ai/api-keys
MISTRAL_API_KEY=

# Available models:
#   mistral-large-latest    — most capable Mistral
#   mistral-medium-latest
#   mistral-small-latest    — fast & efficient
#   open-mistral-nemo       — open-weight, fast
#   open-mixtral-8x22b      — largest open MoE
#   open-mixtral-8x7b       — classic MoE
#   open-mistral-7b         — smallest open model
MISTRAL_MODEL=mistral-large-latest


# ─── Groq (ultra-fast inference) ─────────────────────────────────────────────────
# https://console.groq.com/keys
GROQ_API_KEY=

# Available models:
#   llama-3.3-70b-versatile     — best Llama 3.3, very fast
#   deepseek-r1-distill-llama-70b — DeepSeek R1 distilled
#   llama-3.1-8b-instant        — extremely fast, small
#   mixtral-8x7b-32768          — Mixtral on Groq
#   gemma2-9b-it                — Google Gemma 2 9B
GROQ_MODEL=llama-3.3-70b-versatile


# ─── xAI / Grok ─────────────────────────────────────────────────────────────────
# https://console.x.ai
XAI_API_KEY=

# Available models:
#   grok-3              — latest flagship, strongest
#   grok-3-mini         — fast reasoning
#   grok-3-fast         — speed-optimized
#   grok-2              — previous flagship
#   grok-2-mini         — faster, cheaper
XAI_MODEL=grok-3


# ─── Cohere ─────────────────────────────────────────────────────────────────────
# https://dashboard.cohere.com/api-keys
COHERE_API_KEY=

# Available models:
#   command-r-plus  — most capable, RAG-optimized
#   command-r       — balanced
#   command         — classic flagship
#   command-light   — fast & cheap
COHERE_MODEL=command-r-plus


# ─── Together.ai (fast open-source inference) ────────────────────────────────────
# https://api.together.xyz/settings/api-keys
TOGETHER_API_KEY=

# Available models (full list: https://docs.together.ai/docs/chat-models):
#   meta-llama/Llama-3.3-70B-Instruct-Turbo       — fast Llama 3.3 70B
#   meta-llama/Meta-Llama-3.1-405B-Instruct-Turbo  — largest open model
#   meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo
#   meta-llama/Meta-Llama-3.1-8B-Instruct-Turbo
#   deepseek-ai/DeepSeek-R1                        — full DeepSeek R1 671B
#   deepseek-ai/DeepSeek-V3                        — DeepSeek V3
#   Qwen/Qwen2.5-72B-Instruct-Turbo               — Alibaba Qwen 2.5
#   Qwen/QwQ-32B                                   — Qwen reasoning
#   google/gemma-2-27b-it                          — Google Gemma 2
#   mistralai/Mixtral-8x22B-Instruct-v0.1          — Mixtral large
#   mistralai/Mistral-Small-24B-Instruct-2501
TOGETHER_MODEL=meta-llama/Llama-3.3-70B-Instruct-Turbo


# ─── Ollama (local — no API key required) ────────────────────────────────────────
# https://ollama.com — run models locally for free
OLLAMA_BASE_URL=http://localhost:11434

# Popular models (pull with: ollama pull <model>):
#   llama3.2        — Meta Llama 3.2 (recommended default)
#   llama3.2:1b     — tiny, very fast
#   mistral         — Mistral 7B
#   mistral-nemo    — Mistral Nemo 12B
#   phi4            — Microsoft Phi-4 14B
#   phi3.5          — Microsoft Phi-3.5
#   gemma3          — Google Gemma 3
#   qwen2.5         — Alibaba Qwen 2.5
#   deepseek-r1     — DeepSeek R1 reasoning
#   codellama       — Meta Code Llama
OLLAMA_MODEL=llama3.2


# ─── Developer Experience ──────────────────────────────────────────────────────
# Open the browser automatically when the server starts  (true | false)
AUTO_OPEN_BROWSER=true

# Which framework client to open by default  (threejs | aframe | babylonjs | r3f)
DEFAULT_FRAMEWORK=threejs

# Port of the Vite dev server (used for auto-open URL)
CLIENT_PORT=5173
